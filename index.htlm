                    icon: '🍳',
                    title: 'Desayuno tradicional',
                    desc: '<p class="font-medium text-xs mb-2 text-slate-800">Huevo con ejotes</p><ul class="list-disc pl-4 space-y-1"><li class="mb-1">2 Huevos enteros + 3 claras (100g).</li><li class="mb-1">Ejotes cocidos: 20g + Cebolla/Tomate.</li><li class="mb-1">Frijoles cocidos sin grasa: 1/2 taza.</li><li class="mb-1">Aceite de canola: 2 cditas.</li><li class="mb-1">Tortilla de maíz: 2 piezas.</li></ul>'
                },
                {
                    tag: 'COMIDA',
                    icon: '🐟',
                    title: 'Proteína ligera',
                    desc: '<p class="font-medium text-xs mb-2 text-slate-800">Pescado asado</p><ul class="list-disc pl-4 space-y-1"><li class="mb-1">Filete de pescado: 200 g.</li><li class="mb-1">Aceite de canola: 2 cditas.</li><li class="mb-1">Pepino (1 tza) + Lechuga (1 tza) + 1 Zanahoria.</li><li class="mb-1">Arroz blanco: 1 tza (o 3 tortillas/tostadas).</li><li class="mb-1">Melón: 270 g.</li></ul>'
                },
                {
                    tag: 'CENA',
                    icon: '🥗',
                    title: 'Cena equilibrada',
                    desc: '<p class="font-medium text-xs mb-2 text-slate-800">Quesadilla bowl</p><ul class="list-disc pl-4 space-y-1"><li class="mb-1">Pechuga asada: 70g + Queso Panela Light: 40g.</li><li class="mb-1">Tortilla de maíz: 2 piezas.</li><li class="mb-1">Aguacate: 1/3 pieza + Mayonesa: 1.5 cdita.</li><li class="mb-1">Espinaca, Tomate, Blueberries 15g y 3 Fresas.</li></ul>'
                }
            ]
        };

        function renderCards(day) {
            const container = document.getElementById('menu-container');
            container.innerHTML = ''; // Clear actual

            const data = menuData[day];
            
            data.forEach((meal) => {
                // Determine label bottom text
                let footerLabel = 'BALANCE';
                if(meal.tag.includes('SNACK')) footerLabel = 'INICIO / ENERGÍA';
                else if(meal.tag.includes('DESAYUNO')) footerLabel = 'APORTE MATUTINO';
                else if(meal.tag.includes('COMIDA')) footerLabel = 'COMBUSTIBLE';
                else if(meal.tag.includes('COLACIÓN')) footerLabel = 'SNACK LIGERO';
                else if(meal.tag.includes('CENA')) footerLabel = 'CIERRE';

                const cardHTML = `
                    <div class="bg-white rounded-[1.5rem] p-6 card-shadow border border-slate-100 flex flex-col h-full hover:-translate-y-1 transition-transform duration-300">
                        <div class="flex justify-between items-start mb-4">
                            <span class="text-[10px] font-bold text-primary bg-primary-light px-3 py-1 rounded-full tracking-widest uppercase">${meal.tag}</span>
                            <span class="text-3xl">${meal.icon}</span>
                        </div>
                        ${meal.title ? `<h4 class="font-heading font-semibold text-sm text-slate-800 mb-2">${meal.title}</h4>` : ''}
                        <div class="text-sm text-slate-600 leading-relaxed flex-grow">
                            ${meal.desc}
                        </div>
                        <div class="mt-6 pt-4 border-t border-slate-50">
                            <span class="text-[10px] font-bold text-slate-400 tracking-widest uppercase">${footerLabel}</span>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', cardHTML);
            });
        }

        function setDay(selectedDay) {
            // Transform 'Menú 1' to 'Menú-1' for ID matching
            const safeId = selectedDay.replace(' ', '-');
            
            // Reset styles for all tabs
            document.querySelectorAll('.day-tab').forEach(tab => {
                tab.classList.remove('bg-primary', 'text-white', 'shadow-sm');
                tab.classList.add('text-slate-500');
                tab.classList.remove('text-slate-800'); // ensure it's not dark
            });

            // Set active style for selected tab
            const activeTab = document.getElementById(`tab-${safeId}`);
            if (activeTab) {
                activeTab.classList.remove('text-slate-500');
                activeTab.classList.add('bg-primary', 'text-white', 'shadow-sm');
            }

            // Render cards
            renderCards(selectedDay);
        }

        // Initialize on Menú 1
        document.addEventListener('DOMContentLoaded', () => {
            setDay('Menú 1');
        });
    </script>
</body>
</html>
